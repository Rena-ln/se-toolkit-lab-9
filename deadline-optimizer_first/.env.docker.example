# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_DEBUG=false
BACKEND_CORS_ORIGINS=["http://localhost:8080","http://localhost:5173"]
BACKEND_API_KEY=dev-api-key-change-in-production

# Database
POSTGRES_USER=deadline_user
POSTGRES_PASSWORD=deadline_password
POSTGRES_DB=deadlines
DATABASE_URL=postgresql+asyncpg://deadline_user:deadline_password@postgres:5432/deadlines

# PgAdmin
PGADMIN_EMAIL=admin@deadline-optimizer.local
PGADMIN_DEFAULT_PASSWORD=admin

# Nanobot
NANOBOT_MODEL=coder-model
NANOBOT_PROVIDER=custom
NANOBOT_API_BASE=http://qwen-code-api:42005/v1
NANOBOT_ACCESS_KEY=nanobot-access-key-change
NANOBOT_MAX_TOKENS=8192
NANOBOT_TEMPERATURE=0.1
NANOBOT_MAX_TOOL_ITERATIONS=40

# Qwen Code API (LLM Provider)
QWEN_CODE_API_KEY=your-qwen-api-key

# OpenTelemetry
OTEL_SERVICE_NAME=deadline-optimizer
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# VictoriaLogs
VICTORIALOGS_URL=http://victorialogs:9428

# VictoriaTraces
VICTORIATRACES_URL=http://victoriatraces:8428
